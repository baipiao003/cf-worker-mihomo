{
	"name": "cf-worker-mihomo",
	"version": "1.3.27",
	"description": "Cloudflare Worker for Mihomo subscription service",
	"private": true,
	"license": "MIT",
	"type": "module",
	"scripts": {
		"deploy:workers": "wrangler deploy",
		"deploy": "vercel --prod",
		"build": "node esbuild.js",
		"dev:esbuild": "nodemon -w src -w package.json --exec node dev-esbuild.js",
		"dev:run": "nodemon -w dist/min.js dist/min.js",
		"lint": "prettier --write \"**/*.js\""
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "0.8.47",
		"esbuild": "^0.25.8",
		"nodemon": "^3.1.14",
		"prettier": "^3.6.2",
		"vercel": "^50.37.3",
		"wrangler": "^4.22.0"
	},
	"dependencies": {
		"core-js": "^3.49.0",
		"yaml": "^2.8.0"
	}
}